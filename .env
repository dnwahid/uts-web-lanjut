#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
# Mengaktifkan mode development agar pesan error (jika ada) 
# ditampilkan secara detail di browser.
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
# Mengatur base URL aplikasi sesuai dengan lokasi folder di htdocs
app.baseURL = 'http://localhost/ci4/public/'

# Jika nanti URL aplikasinya menghilangkan 'public' atau 'index.php', 
# konfigurasinya bisa disesuaikan di sini
app.indexPage = ''

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
# Konfigurasi koneksi ke database MySQL/MariaDB bawaan XAMPP
database.default.hostname = localhost
database.default.database = db_akademik
database.default.username = root
database.default.password = 
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESSION (Opsional, dibiarkan default saja)
